<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.PurchaseHistoryController" spacing="10">
    <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
    <TableView fx:id="purchaseTable" prefHeight="400">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="dateColumn" text="Дата" prefWidth="75"/>
            <TableColumn fx:id="costColumn" text="Стоимость" prefWidth="75"/>
            <TableColumn fx:id="clientColumn" text="Клиент" prefWidth="150"/>
        </columns>
    </TableView>
    <Region HBox.hgrow="ALWAYS" />
    <Button text="Назад" onAction="#handleBack" />
</VBox>
