<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.AuthController" spacing="10" alignment="CENTER" prefWidth="300" prefHeight="250">
    <TextField fx:id="nameField" promptText="Full Name" />
    <TextField fx:id="loginField" promptText="Login" />
    <PasswordField fx:id="passwordField" promptText="Password" />
    <Button text="Register" onAction="#handleRegister" />
    <Button text="Back to Login" onAction="#showLoginView" />
</VBox>
