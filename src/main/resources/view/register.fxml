<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.AuthController" spacing="10" alignment="CENTER" prefWidth="300" prefHeight="250">
    <TextField fx:id="nameField" promptText="ФИО" />
    <TextField fx:id="loginField" promptText="Логин" />
    <PasswordField fx:id="passwordField" promptText="Пароль" />
    <Button text="Зарегистрироваться" onAction="#handleRegister" />
    <Button text="Вернуться ко входу" onAction="#showLoginView" />
</VBox>
