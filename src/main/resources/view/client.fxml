<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.ClientController" spacing="10">
    <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
    <TableView fx:id="clientTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="ФИО" prefWidth="150" />
            <TableColumn fx:id="phoneColumn" text="Телефон" prefWidth="150" />
            <TableColumn fx:id="addressColumn" text="Адрес" prefWidth="200" />
        </columns>
    </TableView>
    <HBox spacing="10">
        <Button text="Добавить" onAction="#handleAdd" />
        <Button text="Изменить" onAction="#handleEdit" />
        <Button text="Удалить" onAction="#handleDelete" />
        <Button text="Создать покупку" onAction="#handleCreatePurchase" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Назад" onAction="#handleBack" />
    </HBox>
</VBox>
