<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.VoucherController" spacing="10">
    <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
    <TableView fx:id="voucherTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="hotelColumn" text="Отель" />
            <TableColumn fx:id="durationColumn" text="Длительность" />
            <TableColumn fx:id="priceColumn" text="Цена" />
        </columns>
    </TableView>
    <TextField fx:id="priceField" promptText="Базовая цена" />
    <ComboBox fx:id="durationCombo" promptText="Выберите длительность" />
    <ComboBox fx:id="hotelCombo" promptText="Выберите отель" />
    <HBox spacing="10">
        <Button text="Добавить" onAction="#handleAdd" />
        <Button text="Изменить" onAction="#handleUpdate" />
        <Button text="Удалить" onAction="#handleDelete" />
        <Button text="Назад" onAction="#handleBack" />
    </HBox>
</VBox>
