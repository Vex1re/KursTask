<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.MainController" spacing="10" alignment="CENTER" prefWidth="400" prefHeight="300">
    <Label text="Main Menu" />
    <Button fx:id="editHotelsButton" text="Manage Hotels" onAction="#handleManageHotels" />
    <Button fx:id="editClientsButton" text="Manage Clients" onAction="#handleManageClients" />
    <Button fx:id="createPurchaseButton" text="Create Purchase" onAction="#handleCreatePurchase" />
    <Button text="Logout" onAction="#handleLogout" />
</VBox>
