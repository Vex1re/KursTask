<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.MainController" prefWidth="400" prefHeight="400">
    <top>
        <HBox alignment="TOP_RIGHT" spacing="10">
            <Button text="Профиль" onAction="#handleProfile" />
        </HBox>
    </top>
    <center>
        <VBox spacing="10" alignment="CENTER">
            <Label text="Главное меню" />
            <Button fx:id="editCountriesButton" text="Управление странами" onAction="#handleManageCountries" />
            <Button fx:id="editHotelsButton" text="Управление отелями" onAction="#handleManageHotels" />
            <Button fx:id="editVouchersButton" text="Управление путевками" onAction="#handleManageVouchers" />
            <Button fx:id="editClientsButton" text="Управление клиентами" onAction="#handleManageClients" />
            <Button fx:id="editDiscountsButton" text="Управление скидками" onAction="#handleManageDiscounts" />
            <Button fx:id="purchaseHistoryButton" text="История покупок" onAction="#handlePurchaseHistory" />
            <Button text="Выход" onAction="#handleLogout" />
        </VBox>
    </center>
</BorderPane>
