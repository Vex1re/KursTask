<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.PurchaseController" spacing="10" alignment="CENTER" prefWidth="400" prefHeight="500">
    <Label fx:id="clientLabel" />
    <ComboBox fx:id="countryCombo" promptText="Выберите страну" onAction="#handleCountrySelect" />
    <ComboBox fx:id="hotelCombo" promptText="Выберите отель" />
    <ComboBox fx:id="durationCombo" promptText="Длительность" />
    <DatePicker fx:id="datePicker" promptText="Дата отправления" />
    <ComboBox fx:id="discountCombo" promptText="Выберите скидку" />
    <Button text="Добавить путевку" onAction="#handleAddVoucher" />
    <ListView fx:id="voucherList" prefHeight="100" />
    <Label fx:id="totalCostLabel" text="Итого: 0" />
    <HBox spacing="10" alignment="CENTER">
        <Button text="Назад" onAction="#handleBack" />
        <Button text="Оформить покупку" onAction="#handleCreatePurchase" />
    </HBox>
</VBox>
