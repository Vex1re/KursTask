<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.ProfileController" spacing="10" alignment="CENTER" prefWidth="300" prefHeight="250">
    <TextField fx:id="nameField" promptText="ФИО" />
    <TextField fx:id="loginField" promptText="Логин" editable="false" />
    <PasswordField fx:id="oldPasswordField" promptText="Старый пароль" />
    <PasswordField fx:id="newPasswordField" promptText="Новый пароль" />
    <Button text="Обновить профиль" onAction="#handleUpdate" />
    <Button text="Назад" onAction="#handleBack" />
</VBox>
