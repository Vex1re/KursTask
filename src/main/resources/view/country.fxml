<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.CountryController" spacing="10" padding="10">
    <TableView fx:id="countryTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="nameColumn" text="Название" />
            <TableColumn fx:id="climateColumn" text="Климат" />
        </columns>
    </TableView>
    <TextField fx:id="nameField" promptText="Название страны" />
    <TextField fx:id="climateField" promptText="Климат" />
    <HBox spacing="10">
        <Button text="Добавить" onAction="#handleAdd" />
        <Button text="Изменить" onAction="#handleUpdate" />
        <Button text="Удалить" onAction="#handleDelete" />
    </HBox>
</VBox>
