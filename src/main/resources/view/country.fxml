<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.CountryController" spacing="10">
    <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
    <TableView fx:id="countryTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="nameColumn" text="Название" prefWidth="150"/>
            <TableColumn fx:id="climateColumn" text="Климат" prefWidth="150"/>
        </columns>
    </TableView>
    <TextField fx:id="nameField" promptText="Название страны" />
    <TextField fx:id="climateField" promptText="Климат" />
    <HBox spacing="10">
        <Button text="Добавить" onAction="#handleAdd" />
        <Button text="Изменить" onAction="#handleUpdate" />
        <Button text="Удалить" onAction="#handleDelete" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Назад" onAction="#handleBack" />
    </HBox>
</VBox>
