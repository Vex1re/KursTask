<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.vdm.controller.HotelController" spacing="10">
    <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
    <TableView fx:id="hotelTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="nameColumn" text="Название" prefWidth="150"/>
            <TableColumn fx:id="classColumn" text="Класс" prefWidth="150"/>
            <TableColumn fx:id="countryColumn" text="Страна" prefWidth="150"/>
        </columns>
    </TableView>
    <TextField fx:id="nameField" promptText="Название отеля" />
    <ComboBox fx:id="classCombo" promptText="Выберите класс" />
    <ComboBox fx:id="countryCombo" promptText="Выберите страну" />
    <HBox spacing="10">
        <Button fx:id="addHotelButton" text="Добавить" onAction="#handleAdd" />
        <Button fx:id="editHotelButton" text="Изменить" onAction="#handleUpdate" />
        <Button fx:id="deleteHotelButton" text="Удалить" onAction="#handleDelete" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Назад" onAction="#handleBack" />
    </HBox>
</VBox>
